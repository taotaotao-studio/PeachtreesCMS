# PeachtreesCMS API environment configuration

# Database configuration
DB_HOST=localhost
DB_NAME=peachtrees
DB_USER=root
DB_PASS=111111

# JWT secret (must be changed to a strong random string)
JWT_SECRET=your_strong_random_secret_key_here

# Upload directory (optional)
# Leave empty to use upload/ under the project root
# Production example: /var/www/html/blog/upload/
UPLOAD_DIR=
