# PeachtreesCMS API Environment Configuration
#
# config.php 中已内置默认值，本文件是可选的覆盖配置。
# 没有 .env 也能正常运行（开发 / 快速试用）。
#
# 部署到生产环境时，建议创建 .env 覆盖默认值：
#   1. 复制:  cp .env.example .env
#   2. 编辑:  填入实际的数据库连接信息和 JWT 密钥
#   3. 确保:  .env 不要被提交到版本控制中
#
# 共享主机安全提示：
#   config.php 会自动向上搜索父目录中的 .env 文件（最多 3 层）。
#   如果你使用共享主机（无法设置 nginx），建议将 .env 放在 web root 之外，
#   例如 public_html/ 的上一级目录，这样浏览器无法直接访问：
#
#     /home/your_user/
#     ├── .env                    ← 放在这里（安全）
#     └── public_html/
#         └── blog/
#             ├── index.html
#             └── pt_api/
#
# 默认值（不创建 .env 时使用）：
#   DB_HOST=localhost  DB_NAME=peachtrees  DB_USER=root  DB_PASS=(空)
#   JWT_SECRET=dev-only-insecure-key-CHANGE-ME（⚠️ 生产必须改）

# Database configuration
DB_HOST=localhost
DB_NAME=peachtrees
DB_USER=root
DB_PASS=your_database_password

# JWT secret (must be changed to a strong random string)
JWT_SECRET=your_strong_random_secret_key_here

# Path overrides (all optional — uncomment and fill for custom deployment)
# Default: auto-detected relative to project root
# UPLOAD_DIR=/var/www/html/blog/upload
# THEME_DIR=/var/www/html/blog/theme
# STYLE_DIR=/var/www/html/blog/pattern
